# Database Configuration
DATABASE_URL=postgresql://postgres:1234@localhost:5432/mini_auth_server?schema=public

# Server Configuration
PORT=3000

# CORS Configuration
CORS_ORIGIN=*

# JWT Configuration
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=https://auth.local
JWT_AUDIENCE=mini-auth-api
JWT_ACCESS_EXPIRES_IN=1800 # 30 minutes